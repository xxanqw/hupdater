import { Button, VerticalBox, HorizontalBox, ComboBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Helium Browser Autoupdater";
    icon: @image-url("../assets/icon.png");
    preferred-width: 520px;
    preferred-height: 450px;
    min-width: 520px;
    max-width: 520px;
    min-height: 450px;
    max-height: 450px;
    background: #171717;

    in property <string> install-status: "Installed (Registry & Winget)";
    in property <string> task-info: "Ready";
    in-out property <bool> is-busy: false;
    in-out property <bool> use-winget: false;
    in-out property <bool> interceptor-enabled: false;
    in-out property <bool> controls-enabled: false;

    callback trigger-update();
    callback enable-interceptor();
    callback restore-interceptor();
    callback uninstall-updater();
    callback save-settings(bool);

    VerticalBox {
        padding: 0;
        spacing: 0;

        VerticalBox {
            padding: 20px;
            spacing: 14px;
            alignment: start;
            vertical-stretch: 1;

            VerticalBox {
                spacing: 4px;
                padding: 0;

                Text {
                    text: "HUpdater";
                    font-size: 24px;
                    font-weight: 700;
                    color: #ffffff;
                }

                Text {
                    text: "Perfect way to autoupdate Helium in its alpha stage (config autoapplies)";
                    font-size: 13px;
                    color: #9a9a9a;
                }
            }

            Rectangle {
                background: #202020;
                border-radius: 8px;
                border-width: 1px;
                border-color: #333333;

                VerticalBox {
                    padding: 14px;
                    spacing: 10px;

                    Text {
                        text: "HELIUM";
                        font-size: 11px;
                        font-weight: 700;
                        color: #888888;
                        letter-spacing: 0.5px;
                    }

                    Text {
                        text: root.install-status;
                        font-size: 14px;
                        font-weight: 600;
                        color: #efefef;
                    }

                    Rectangle { height: 1px; background: #333333; }

                    HorizontalLayout {
                        spacing: 16px;

                        Text {
                            text: "Check for updates or install silently.";
                            font-size: 13px;
                            color: #aaaaaa;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        Button {
                            text: root.is-busy ? "Processing..." : "Check / Install";
                            enabled: root.controls-enabled && !root.is-busy;
                            primary: true;
                            width: 180px;
                            clicked => { root.trigger-update(); }
                        }
                    }
                }
            }

            Rectangle {
                background: #202020;
                border-radius: 8px;
                border-width: 1px;
                border-color: #333333;

                VerticalBox {
                    padding: 14px;
                    spacing: 10px;

                    Text {
                        text: "CONFIGURATION";
                        font-size: 11px;
                        font-weight: 700;
                        color: #888888;
                        letter-spacing: 0.5px;
                    }

                    HorizontalLayout {
                        spacing: 16px;

                        Text {
                            text: "Preferred update source";
                            font-size: 13px;
                            color: #aaaaaa;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        ComboBox {
                            model: ["GitHub Installer", "Winget"];
                            current-index: root.use-winget ? 1 : 0;
                            enabled: root.controls-enabled;
                            width: 160px;
                            selected(val) => {
                                root.use-winget = (val == "Winget");
                                root.save-settings(root.use-winget);
                            }
                        }
                    }

                    Rectangle { height: 1px; background: #333333; }

                    HorizontalLayout {
                        spacing: 16px;

                        Text {
                            text: "Route Helium shortcuts through HUpdater.";
                            font-size: 13px;
                            color: #aaaaaa;
                            vertical-alignment: center;
                            wrap: word-wrap;
                            horizontal-stretch: 1;
                        }

                        HorizontalLayout {
                            spacing: 8px;

                            Button {
                                text: "Enable";
                                enabled: root.controls-enabled && !root.interceptor-enabled;
                                clicked => { root.enable-interceptor(); }
                            }

                            Button {
                                text: "Restore";
                                enabled: root.controls-enabled && root.interceptor-enabled;
                                clicked => { root.restore-interceptor(); }
                            }
                        }
                    }

                    Rectangle { height: 1px; background: #333333; }

                    HorizontalLayout {
                        spacing: 16px;

                        Text {
                            text: "Remove the updater from your system";
                            font-size: 13px;
                            color: #aaaaaa;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        Button {
                            text: "Uninstall Updater";
                            enabled: root.controls-enabled;
                            clicked => { root.uninstall-updater(); }
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 24px;
            background: #1b1b1b;
            border-radius: 0px;
            horizontal-stretch: 1;

            Rectangle {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: 1px;
                background: #2a2a2a;
            }

            Text {
                text: "Status: " + root.task-info;
                font-size: 11px;
                color: #8da4ba;
                x: 8px;
                y: (parent.height - self.height) / 2;
            }
        }
    }
}
